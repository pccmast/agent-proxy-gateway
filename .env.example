# Agent Gateway API Keys
# Copy this file to .env and fill in your actual keys
# .env is gitignored — never commit real keys

# OpenAI (or compatible API like DeepSeek)
OPENAI_API_KEY=sk-your-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek (OpenAI-compatible format)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Eval LLM Judge (optional)
EVAL_LLM_API_KEY=sk-your-eval-key-here
