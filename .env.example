# Agent Gateway API Keys
# Copy this file to .env and fill in your actual keys
# .env is gitignored — never commit real keys

# OpenAI-compatible API (used for all OpenAI-adapter requests)
# Also works with DeepSeek, LM Studio, vLLM, Ollama, etc.
OPENAI_API_KEY=sk-your-key-here

# Anthropic
ANTHROPIC_API_KEY=sk-ant-your-key-here

# DeepSeek (OpenAI-compatible format, can share same key as OPENAI_API_KEY)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# LM Studio (local dev — base_url in default.yaml already points here)
# LM Studio runs on http://localhost:1234 by default, no API key needed.
# To use it: set OPENAI_API_KEY=not-needed and update default.yaml
